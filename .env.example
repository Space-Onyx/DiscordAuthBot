# Discord bot token (обязателен)
DISCORD_KEY=PUT_DISCORD_BOT_TOKEN_HERE

# GitHub token для git-команд бота (опционально)
USER_KEY_GITHUB=PUT_GITHUB_TOKEN_HERE

# Сервисный админ для Actor в admin API
ADMIN_GUID=PUT_SS14_ADMIN_GUID_HERE
ADMIN_NAME=DiscordBot

# Глобальный fallback admin API токен
ADMIN_API=PUT_GLOBAL_ADMIN_API_TOKEN_HERE

# User-Agent для Watchdog запросов
POST_USER_AGENT=DiscordAuthBot/1.0

# API бота для глобальной отвязки (SS14 -> Bot)
BOT_API_TOKEN=PUT_BOT_API_TOKEN_HERE
BOT_API_HOST=127.0.0.1
BOT_API_PORT=8088

